#include <iostream>
#include <opencv2/opencv.hpp>
#include <vector>
#include <cmath>
#include <windows.h>

#include "tensorflow/lite/interpreter.h"
#include "tensorflow/lite/kernels/register.h"
#include "tensorflow/lite/model.h"


const float PINCH_THRESHOLD = 35.0f;            // порог клика (пиксели)
const int PINCH_COOLDOWN_FRAMES = 5;            // защита от спама
const float SMOOTH_FACTOR = 1.0f;               // сглаживание (1.0 - отключено)
const int FILTER_HISTORY_SIZE = 1;               // размер фильтра координат (1 - отключен)
const float IOU_THRESHOLD = 0.3f;                // для трекинга бокса
const float SENSITIVITY = 1.0f;                  // чувствительность (>1 быстрее, <1 медленнее)
const float CROP_FACTOR = 0.8f;                   // доля центра кадра, проецируемая на весь экран (0..1)


const int CAMERA_WIDTH = 640;
const int CAMERA_HEIGHT = 480;


struct BoundingBox {
    float x_center, y_center, width, height;
    float confidence;
};

struct PinchState {
    bool pinching = false;
    int cooldown = 0;
};


int virtualScreenWidth, virtualScreenHeight;   
int smooth_x = 0, smooth_y = 0;
PinchState pinchState;
std::vector<float> history_x, history_y;       
HWND g_hWnd = nullptr;                         


void moveMouse(int x, int y) {
#ifdef _WIN32
    SetCursorPos(x, y);
#endif
}

void mouseClick() {
#ifdef _WIN32
    INPUT inputs[2] = {};
    inputs[0].type = INPUT_MOUSE;
    inputs[0].mi.dwFlags = MOUSEEVENTF_LEFTDOWN;
    inputs[1].type = INPUT_MOUSE;
    inputs[1].mi.dwFlags = MOUSEEVENTF_LEFTUP;
    SendInput(2, inputs, sizeof(INPUT));
    std::cout << "Click!" << std::endl;
#endif
}

void smoothCoordinates(int new_x, int new_y, int &out_x, int &out_y) {
    if (smooth_x == 0 && smooth_y == 0) {
        smooth_x = new_x;
        smooth_y = new_y;
    } else {
        smooth_x = static_cast<int>(smooth_x * (1 - SMOOTH_FACTOR) + new_x * SMOOTH_FACTOR);
        smooth_y = static_cast<int>(smooth_y * (1 - SMOOTH_FACTOR) + new_y * SMOOTH_FACTOR);
    }
    out_x = smooth_x;
    out_y = smooth_y;
}

cv::Rect boxToRect(const BoundingBox& box, int frame_width, int frame_height) {
    int x = static_cast<int>((box.x_center - box.width/2) * frame_width);
    int y = static_cast<int>((box.y_center - box.height/2) * frame_height);
    int w = static_cast<int>(box.width * frame_width);
    int h = static_cast<int>(box.height * frame_height);
    return cv::Rect(x, y, w, h);
}

float computeIoU(const cv::Rect& rect1, const cv::Rect& rect2) {
    cv::Rect intersection = rect1 & rect2;
    float area_intersection = intersection.area();
    float area_union = rect1.area() + rect2.area() - area_intersection;
    return area_union > 0 ? area_intersection / area_union : 0;
}

std::unique_ptr<tflite::Interpreter> loadModel(const std::string& model_path,
                                               int& input_width, int& input_height) {
    std::cout << "Loading model: " << model_path << std::endl;
    auto model = tflite::FlatBufferModel::BuildFromFile(model_path.c_str());
    if (!model) {
        std::cerr << "Failed to load model: " << model_path << std::endl;
        return nullptr;
    }

    tflite::ops::builtin::BuiltinOpResolver resolver;
    std::unique_ptr<tflite::Interpreter> interpreter;
    tflite::InterpreterBuilder(*model, resolver)(&interpreter);
    if (!interpreter) {
        std::cerr << "Failed to create interpreter for: " << model_path << std::endl;
        return nullptr;
    }

    if (interpreter->AllocateTensors() != kTfLiteOk) {
        std::cerr << "Failed to allocate tensors for: " << model_path << std::endl;
        return nullptr;
    }

    int input_index = interpreter->inputs()[0];
    TfLiteTensor* input_tensor = interpreter->tensor(input_index);
    if (input_tensor->dims->size == 4) {
        input_height = input_tensor->dims->data[1];
        input_width = input_tensor->dims->data[2];
    } else {
        std::cerr << "Unexpected input tensor dimensions" << std::endl;
        return nullptr;
    }

    std::cout << "Model loaded. Input size: " << input_width << "x" << input_height << std::endl;
    return interpreter;
}

std::vector<BoundingBox> decodePalmDetections(float* output_data, float threshold = 0.5f) {
    std::vector<BoundingBox> detections;
    int num_anchors = 2016; // фиксировано для данной модели
    for (int i = 0; i < num_anchors; ++i) {
        float score = output_data[i * 18 + 4];
        if (score > threshold) {
            BoundingBox box;
            box.x_center = output_data[i * 18 + 0];
            box.y_center = output_data[i * 18 + 1];
            box.width    = output_data[i * 18 + 2];
            box.height   = output_data[i * 18 + 3];
            box.confidence = score;
            detections.push_back(box);
        }
    }
    return detections;
}

int main() {
    std::cout << "=== Hand Mouse ===" << std::endl;

    virtualScreenWidth = GetSystemMetrics(SM_CXVIRTUALSCREEN);
    virtualScreenHeight = GetSystemMetrics(SM_CYVIRTUALSCREEN);
    std::cout << "Virtual screen: " << virtualScreenWidth << "x" << virtualScreenHeight << std::endl;

    int palm_width, palm_height, lm_width, lm_height;
    auto palm_interpreter = loadModel("palm_detection.tflite", palm_width, palm_height);
    auto lm_interpreter   = loadModel("hand_landmark.tflite", lm_width, lm_height);

    if (!palm_interpreter || !lm_interpreter) {
        std::cerr << "Model loading failed!" << std::endl;
        std::cin.get();
        return -1;
    }

    // Открываем камеру
    cv::VideoCapture cap(0, cv::CAP_DSHOW);
    if (!cap.isOpened()) {
        std::cerr << "Cannot open camera!" << std::endl;
        std::cin.get();
        return -1;
    }

    // Устанавливаем разрешение
    cap.set(cv::CAP_PROP_FRAME_WIDTH, CAMERA_WIDTH);
    cap.set(cv::CAP_PROP_FRAME_HEIGHT, CAMERA_HEIGHT);
    int actual_width  = static_cast<int>(cap.get(cv::CAP_PROP_FRAME_WIDTH));
    int actual_height = static_cast<int>(cap.get(cv::CAP_PROP_FRAME_HEIGHT));
    std::cout << "Camera resolution: " << actual_width << "x" << actual_height << std::endl;

    history_x.assign(FILTER_HISTORY_SIZE, 0.5f);
    history_y.assign(FILTER_HISTORY_SIZE, 0.5f);

    cv::Mat frame;
    cv::Rect previous_roi;
    bool use_previous_roi = false;
    int last_valid_x = -1, last_valid_y = -1;

    cv::namedWindow("Hand Mouse (Absolute)", cv::WINDOW_AUTOSIZE);

    std::cout << "Running. Press ESC to exit." << std::endl;

    while (true) {
        // Захват кадра
        cap >> frame;
        if (frame.empty()) break;
        cv::flip(frame, frame, 1);

        cv::Rect hand_roi;
        bool hand_found = false;

        if (!use_previous_roi) {
            cv::Mat palm_input;
            cv::resize(frame, palm_input, cv::Size(palm_width, palm_height));
            palm_input.convertTo(palm_input, CV_32FC3, 1.0 / 255.0);

            float* input_data = palm_interpreter->typed_input_tensor<float>(0);
            memcpy(input_data, palm_input.data, palm_input.total() * palm_input.elemSize());

            if (palm_interpreter->Invoke() == kTfLiteOk) {
                float* output_data = palm_interpreter->typed_output_tensor<float>(0);
                auto detections = decodePalmDetections(output_data, 0.5f);

                if (!detections.empty()) {
                    auto& best = detections[0];
                    hand_roi = boxToRect(best, frame.cols, frame.rows);
                    hand_found = true;
                }
            }
        } else {
            hand_roi = previous_roi;
            hand_found = true;
        }

        if (hand_found) {
            hand_roi.x = std::max(0, hand_roi.x - hand_roi.width/4);
            hand_roi.y = std::max(0, hand_roi.y - hand_roi.height/4);
            hand_roi.width  = std::min(frame.cols - hand_roi.x, hand_roi.width + hand_roi.width/2);
            hand_roi.height = std::min(frame.rows - hand_roi.y, hand_roi.height + hand_roi.height/2);

            cv::Mat hand_crop = frame(hand_roi);

            cv::Mat lm_input;
            cv::resize(hand_crop, lm_input, cv::Size(lm_width, lm_height));
            lm_input.convertTo(lm_input, CV_32FC3, 1.0 / 255.0);

            float* lm_input_data = lm_interpreter->typed_input_tensor<float>(0);
            memcpy(lm_input_data, lm_input.data, lm_input.total() * lm_input.elemSize());

            if (lm_interpreter->Invoke() == kTfLiteOk) {
                float* lm_output = lm_interpreter->typed_output_tensor<float>(0);

                std::vector<cv::Point> points;
                for (int i = 0; i < 21; ++i) {
                    float x_rel = lm_output[i*3] / lm_width;
                    float y_rel = lm_output[i*3+1] / lm_height;

                    int x_abs = hand_roi.x + static_cast<int>(x_rel * hand_roi.width);
                    int y_abs = hand_roi.y + static_cast<int>(y_rel * hand_roi.height);

                    points.emplace_back(x_abs, y_abs);
                    cv::circle(frame, cv::Point(x_abs, y_abs), 2, cv::Scalar(0,255,0), -1);
                }

                bool currently_pinching = false;
                if (points.size() > 8 && points.size() > 4) {
                    cv::Point thumb = points[4];
                    cv::Point index = points[8];
                    float distance = cv::norm(thumb - index);
                    currently_pinching = (distance < PINCH_THRESHOLD);

                    cv::line(frame, thumb, index, cv::Scalar(255,0,255), 2);
                    if (currently_pinching) {
                        cv::line(frame, thumb, index, cv::Scalar(0,0,255), 3);
                        cv::putText(frame, "PINCH", cv::Point(10,30), cv::FONT_HERSHEY_SIMPLEX, 1, cv::Scalar(0,255,255), 2);
                    }
                }

                if (pinchState.cooldown > 0) pinchState.cooldown--;
                if (currently_pinching && !pinchState.pinching && pinchState.cooldown == 0) {
                    mouseClick();
                    pinchState.pinching = true;
                    pinchState.cooldown = PINCH_COOLDOWN_FRAMES;
                } else if (!currently_pinching && pinchState.pinching) {
                    pinchState.pinching = false;
                }

                if (points.size() > 8) {
                    // Нормализованные координаты указательного пальца (0..1)
                    float norm_x = (float)points[8].x / frame.cols;
                    float norm_y = (float)points[8].y / frame.rows;

                    float low = (1.0f - CROP_FACTOR) / 2.0f;
                    float high = 1.0f - low;

                    float mapped_x, mapped_y;

                    if (norm_x < low)
                        mapped_x = 0.0f;
                    else if (norm_x > high)
                        mapped_x = 1.0f;
                    else
                        mapped_x = (norm_x - low) / (high - low);

                    if (norm_y < low)
                        mapped_y = 0.0f;
                    else if (norm_y > high)
                        mapped_y = 1.0f;
                    else
                        mapped_y = (norm_y - low) / (high - low);

                    mapped_x = 0.5f + (mapped_x - 0.5f) * SENSITIVITY;
                    mapped_y = 0.5f + (mapped_y - 0.5f) * SENSITIVITY;
                    mapped_x = std::max(0.0f, std::min(1.0f, mapped_x));
                    mapped_y = std::max(0.0f, std::min(1.0f, mapped_y));

                    int screen_x = static_cast<int>(mapped_x * virtualScreenWidth);
                    int screen_y = static_cast<int>(mapped_y * virtualScreenHeight);
                    screen_x = std::max(0, std::min(virtualScreenWidth, screen_x));
                    screen_y = std::max(0, std::min(virtualScreenHeight, screen_y));

                    // Сглаживание (если нужно, но SMOOTH_FACTOR=1.0)
                    int final_x, final_y;
                    smoothCoordinates(screen_x, screen_y, final_x, final_y);
                    moveMouse(final_x, final_y);

                    // Выделяем указательный палец
                    cv::circle(frame, points[8], 5, cv::Scalar(0,0,255), 2);
                }

                float iou = computeIoU(hand_roi, previous_roi);
                if (iou > IOU_THRESHOLD) {
                    previous_roi = hand_roi;
                    use_previous_roi = true;
                } else {
                    use_previous_roi = false;
                }
            } else {
                use_previous_roi = false;
            }
        } else {
            use_previous_roi = false;
            smooth_x = smooth_y = 0; 
        }

        if (hand_found) {
            cv::rectangle(frame, hand_roi, cv::Scalar(255,0,0), 2);
        }

        if (g_hWnd == nullptr) {
            g_hWnd = FindWindowW(nullptr, L"Hand Mouse (Absolute)");
        }

        bool windowActive = true;
        if (g_hWnd) {
            if (IsIconic(g_hWnd) || !IsWindowVisible(g_hWnd)) {
                windowActive = false;
            }
        } else {
            HWND consoleWnd = GetConsoleWindow();
            if (IsIconic(consoleWnd) || GetForegroundWindow() != consoleWnd) {
                windowActive = false;
            }
        }

        if (windowActive) {
            cv::imshow("Hand Mouse (Absolute)", frame);
            if (cv::waitKey(10) == 27) break;
        } else {
            cv::waitKey(1);
    }

    cap.release();
    cv::destroyAllWindows();
    std::cout << "Done. Press Enter to exit." << std::endl;
    std::cin.get();
    return 0;
}
